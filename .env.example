# Database
DB_ROOT_PASSWORD=rootpassword

# Redis
REDIS_ADDR=localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# Encryption (AES-256 key, base64 encoded)
ENCRYPTION_KEY=change-me-to-a-secure-32-byte-key-base64-encoded

# Service ports (used when running outside Docker)
USER_SERVICE_PORT=8081
EVENT_SERVICE_PORT=8082
TICKET_SERVICE_PORT=8083
EMAIL_SERVICE_PORT=8084
